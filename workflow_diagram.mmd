---
title: Beaver's Choice Paper Company — Multi-Agent System Workflow
---
flowchart TD
    Customer([Customer Request<br/>text + request date])

    subgraph Orch["Orchestration"]
        Orchestrator{{"1 - orchestrator_agent<br/>parse request, delegate to<br/>managed agents, compose reply"}}
    end

    subgraph Agents["Specialist Agents (smolagents ToolCallingAgent)"]
        direction LR
        Inventory["2 - inventory_agent<br/>stock lookups +<br/>restock decisions"]
        Quoting["3 - quoting_agent<br/>pricing, bulk discounts,<br/>quote history"]
        Sales["4 - sales_agent<br/>finalize sale, delivery<br/>timeline, finances"]
    end

    subgraph Tools["Agent Tools (@tool, wrap project_solution helpers)"]
        direction TB
        T1[/"check_inventory<br/>get_stock_level"/]
        T2[/"get_inventory_snapshot<br/>get_all_inventory"/]
        T3[/"restock_item<br/>create_transaction (stock_orders)"/]
        T4[/"get_quote_history<br/>search_quote_history"/]
        T5[/"generate_quote<br/>catalog price + bulk discount"/]
        T6[/"finalize_sale<br/>create_transaction (sales)"/]
        T7[/"check_delivery_date<br/>get_supplier_delivery_date"/]
        T8[/"get_financial_report<br/>generate_financial_report"/]
    end

    DB[("beavers_choice.db<br/>SQLite — transactions,<br/>inventory, quotes")]

    %% Customer flow
    Customer -->|inquiry| Orchestrator

    %% Delegation (managed_agents)
    Orchestrator -->|"check stock /<br/>restock?"| Inventory
    Orchestrator -->|"generate quote"| Quoting
    Orchestrator -->|"finalize order"| Sales

    %% Inventory tools
    Inventory --> T1
    Inventory --> T2
    Inventory --> T3

    %% Quoting tools
    Quoting --> T4
    Quoting --> T5

    %% Sales tools
    Sales --> T6
    Sales --> T7
    Sales --> T8

    %% Tools to DB
    T1 --> DB
    T2 --> DB
    T3 --> DB
    T4 --> DB
    T6 --> DB
    T8 --> DB

    %% Responses back up
    Inventory -.->|stock status| Orchestrator
    Quoting -.->|quote + discount| Orchestrator
    Sales -.->|confirmation +<br/>delivery date| Orchestrator
    Orchestrator -->|"final text response"| Customer

    classDef agent fill:#2563eb,stroke:#1e3a8a,color:#fff;
    classDef tool fill:#f1f5f9,stroke:#64748b,color:#0f172a;
    classDef db fill:#16a34a,stroke:#166534,color:#fff;
    class Orchestrator,Inventory,Quoting,Sales agent;
    class T1,T2,T3,T4,T5,T6,T7,T8 tool;
    class DB db;
